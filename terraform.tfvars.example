
# Networking
vpc_cidr = "10.0.xxxxx" # add your on cidr
availability_zones = [
  "us-xxxx", #add whatever availability_zones you are working with
  "us-xxxxxx"
]

# EC2 configuration
ec2_ami       = "ami-xxxxxxxx" #add your own ami
key_name      = "myxxxxxxx" #add your own key_name


domain_name = "dexxxxxxxx" #your own domain_name

certificate_arn = "arn:aws:axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" #add your own acm generated by aws
hosted_zone_id= "Z0XXXXXXXXX" #add your own hosted_zone_id
s3_bucket_name = "XXXXXX" #add your own s3_bucket_name
subdomain="xxx" #add a subdomain of your choice